# Supabase (anon jwt or publishable key both work as VITE_SUPABASE_ANON_KEY)
# URL должен быть вида https://<ref>.supabase.co (без /rest/v1 и без слэша в конце).
# Если в DevTools запросы к Supabase висят (pending): проверьте URL и ключ в Dashboard,
# что проект не на паузе, VPN/файрвол и что в .env нет лишних кавычек/пробелов.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Venice AI breakdown (POST JSON {"task":"..."}).
# Пустое значение: в `npm run dev` запросы идут на /api/venice/breakdown (Vite proxy, без внешнего CORS);
# production build — прямой URL в коде, либо задеплойте workers/venice-cors-proxy и укажите его URL здесь (Access-Control-Allow-Origin: *).
# VITE_VENICE_BREAKDOWN_URL=/api/venice/breakdown
# VITE_VENICE_BREAKDOWN_URL=https://YOUR-account.workers.dev

# Google OAuth: no keys in this file. Create OAuth Client in Google Cloud Console,
# then paste Client ID + Client Secret in Supabase Dashboard → Authentication → Providers → Google.
# In Google Cloud, set Authorized redirect URI to:
#   https://<your-project-ref>.supabase.co/auth/v1/callback
